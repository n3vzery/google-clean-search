{
  "manifest_version": 3,
  "name": "Google Clean Search",
  "version": "4.2",
  "description": "Removes account cookies from Google search requests. Keeps you logged in.",

  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "storage",
    "cookies",
    "alarms"
  ],

  "host_permissions": [
    "https://*.google.com/*",
    "https://google.com/*",
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://chromewebstore.google.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png"
    }
  },

  "icons": {
    "16": "icon16.png",
    "48": "icon48.png"
  }
}
